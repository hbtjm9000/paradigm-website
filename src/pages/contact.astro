---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout title="Contact" description="Contact Paradigm IT Services for IT consulting, digital transformation, and managed services. Located in Kingston, Jamaica. Book a consultation with our CEO.">
  <section class="bg-gradient-to-br from-tertiary via-secondary/20 to-tertiary text-white py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-display-lg font-display font-bold mb-6">Contact Us</h1>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto">
        Ready to transform your business with technology? Get in touch and let us start the conversation.
      </p>
    </div>
  </section>

  <section class="py-20 lg:py-28 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div>
          <ContactForm />
        </div>
        
        <div class="space-y-8">
          <div>
            <h2 class="text-2xl font-display font-semibold text-secondary mb-6">Get in Touch</h2>
            <p class="text-ink-muted text-lg">
              Whether you have a specific project in mind or just want to explore possibilities, we would love to hear from you. Fill out the form and we will respond within 24 hours.
            </p>
          </div>
          
          <div class="bg-white p-6 border border-gray-200">
            <h3 class="text-lg font-display font-semibold text-secondary mb-4">Contact Information</h3>
            <ul class="space-y-4">
              <li class="flex items-start space-x-3">
                <svg class="h-6 w-6 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <div>
                  <div class="font-medium text-secondary">Office Location</div>
                  <div class="text-ink-muted">Kingston, Jamaica</div>
                </div>
              </li>
              
              <li class="flex items-start space-x-3">
                <svg class="h-6 w-6 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <div>
                  <div class="font-medium text-secondary">Email</div>
                  <a href="mailto:hello@serviceparadigm.com" class="text-primary hover:underline">hello@serviceparadigm.com</a>
                </div>
              </li>
              
              <li class="flex items-start space-x-3">
                <svg class="h-6 w-6 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div>
                  <div class="font-medium text-secondary">Business Hours</div>
                  <div class="text-ink-muted">Monday - Friday: 9:00 AM - 5:00 PM (Jamaica Time)</div>
                </div>
              </li>
            </ul>
          </div>
          
          <div class="bg-white p-6 border border-gray-200">
            <h3 class="text-lg font-display font-semibold text-secondary mb-4">Connect With Us</h3>
            <div class="flex space-x-4">
              <a href="https://linkedin.com/company/paradigm-it" target="_blank" rel="noopener noreferrer" class="p-3 bg-gray-100 text-ink-muted hover:text-primary hover:bg-primary/10 transition-colors" aria-label="LinkedIn">
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
            </div>
          </div>
          
          <div class="bg-primary/10 p-6">
            <div class="flex items-center space-x-3 mb-3">
              <svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="text-xl font-display font-semibold text-secondary">24-Hour Response</span>
            </div>
            <p class="text-ink-muted">
              We commit to responding to all inquiries within 24 business hours. For urgent matters, please call or email directly.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
