---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout 
  title="Contact — Paradigm IT Services"
  description="Get in touch with Paradigm IT Services. Book a consultation, ask a question, or start a conversation about your IT needs."
>
  <!-- Page Header -->
  <section class="pt-32 pb-16 bg-tertiary">
    <div class="max-w-7xl mx-auto px-6">
      <span class="font-space text-xs font-semibold uppercase tracking-[0.25em] text-secondary-fixed mb-4 block">Get in Touch</span>
      <h1 class="font-fraunces font-bold text-white text-5xl md:text-6xl leading-tight mb-6 max-w-3xl drop-shadow-ink">
        Let's Start a Conversation
      </h1>
      <p class="font-outfit font-light text-white/80 text-xl max-w-2xl leading-relaxed">
        Whether you have a clear brief or just a vague idea — we'd love to hear from you.
      </p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-24 bg-white" aria-label="Contact information and form">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20">
        
        <!-- Form -->
        <div>
          <span class="font-space text-xs font-semibold uppercase tracking-[0.25em] text-secondary mb-4 block">Send a Message</span>
          <h2 class="font-fraunces font-bold text-secondary text-3xl mb-2">Book a Consultation</h2>
          <p class="font-outfit text-on-surface-variant text-base mb-10 leading-relaxed">
            Fill out the form below and we'll get back to you within one business day.
          </p>
          <ContactForm />
        </div>

        <!-- Contact Info -->
        <div>
          <span class="font-space text-xs font-semibold uppercase tracking-[0.25em] text-secondary mb-4 block">Direct Contact</span>
          <h2 class="font-fraunces font-bold text-secondary text-3xl mb-10">Other Ways to Reach Us</h2>
          
          <div class="space-y-8">
            <!-- Email -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-primary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-fraunces font-semibold text-secondary text-base mb-1">Email</h3>
                <a href="mailto:hello@serviceparadigm.com" class="font-outfit text-on-surface-variant hover:text-primary transition-colors">
                  hello@serviceparadigm.com
                </a>
              </div>
            </div>

            <!-- Phone -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-secondary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="h-5 w-5 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="font-fraunces font-semibold text-secondary text-base mb-1">Phone</h3>
                <a href="tel:+18765550199" class="font-outfit text-on-surface-variant hover:text-primary transition-colors">
                  +1 (876) 555-0199
                </a>
                <p class="font-outfit text-on-surface-variant/60 text-sm mt-1">Mon–Fri, 8am–6pm EST</p>
              </div>
            </div>

            <!-- Location -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-tertiary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="h-5 w-5 text-tertiary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-fraunces font-semibold text-secondary text-base mb-1">Office</h3>
                <p class="font-outfit text-on-surface-variant">
                  Kingston, Jamaica<br/>
                  Caribbean
                </p>
              </div>
            </div>

            <!-- LinkedIn -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-secondary-fixed/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="h-5 w-5 text-secondary-fixed" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-fraunces font-semibold text-secondary text-base mb-1">LinkedIn</h3>
                <a 
                  href="https://linkedin.com/company/paradigm-it-services"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-outfit text-on-surface-variant hover:text-primary transition-colors"
                >
                  Paradigm IT Services
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
