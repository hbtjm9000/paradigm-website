---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
---

<BaseLayout 
  title="Packaged AI — Paradigm IT Services"
  description="Ready-to-deploy AI solutions for Caribbean businesses. No PhD required — we build, deploy, and maintain everything."
>
  <!-- Hero -->
  <section class="pt-32 pb-24 bg-secondary relative overflow-hidden" aria-label="Packaged AI hero">
    <div class="absolute inset-0 opacity-[0.05]" 
      style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 48px 48px;">
    </div>
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="max-w-3xl">
        <span class="inline-block font-space text-xs font-semibold uppercase tracking-[0.25em] text-primary mb-6 px-3 py-1.5 border border-primary/30">
          Product · Packaged AI
        </span>
        <h1 class="font-fraunces font-bold text-white text-5xl md:text-7xl leading-tight mb-8 drop-shadow-ink">
          AI That Works.<br/>Out of the Box.
        </h1>
        <p class="font-outfit font-light text-white/80 text-xl md:text-2xl leading-relaxed mb-10 max-w-2xl">
          Pre-built AI solutions for the most common Caribbean business challenges — designed, deployed, and maintained by our team. No internal AI expertise required.
        </p>
        <div class="flex flex-wrap gap-4">
          <Button href="/contact" label="See Pricing" icon={true} />
          <Button variant="secondary" href="/contact" label="Book Consultation" />
        </div>
      </div>
    </div>
  </section>

  <!-- Solutions -->
  <section class="py-24 bg-white" aria-labelledby="solutions-heading">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16 max-w-2xl mx-auto">
        <span class="font-space text-xs font-semibold uppercase tracking-[0.25em] text-secondary mb-4 block">What We Offer</span>
        <h2 id="solutions-heading" class="font-fraunces font-bold text-secondary text-4xl md:text-5xl leading-tight">
          Solutions Built for Real Caribbean Business Problems
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          {
            title: 'AI Customer Service',
            desc: 'Deploy a RAG-powered chatbot trained on your knowledge base. Handles 80% of customer queries automatically, routes the rest to your team.',
            icon: 'chat',
            timeline: '2–3 weeks to deploy',
          },
          {
            title: 'Automated Reporting',
            desc: 'Weekly or monthly reports generated from your data — sales, operations, financials — delivered to your inbox without manual work.',
            icon: 'report',
            timeline: '1–2 weeks to deploy',
          },
          {
            title: 'Lead Qualification',
            desc: 'AI that qualifies inbound leads, scores them by likelihood to convert, and routes them to the right salesperson.',
            icon: 'filter',
            timeline: '2–4 weeks to deploy',
          },
          {
            title: 'Document Processing',
            desc: 'Extract data from invoices, contracts, and forms automatically. Goodbye manual data entry.',
            icon: 'doc',
            timeline: '2–3 weeks to deploy',
          },
          {
            title: 'Demand Forecasting',
            desc: 'Predict inventory needs, staffing requirements, and cash flow with ML models trained on your historical data.',
            icon: 'chart',
            timeline: '3–6 weeks to deploy',
          },
          {
            title: 'AI-Powered Search',
            desc: 'Semantic search across your documents, emails, and databases. Find anything by asking in plain English.',
            icon: 'search',
            timeline: '1–2 weeks to deploy',
          },
        ].map(s => (
          <div class="p-8 bg-surface group hover:bg-tertiary transition-colors duration-300">
            <h3 class="font-fraunces font-semibold text-secondary group-hover:text-white text-xl mb-4 leading-snug transition-colors">{s.title}</h3>
            <p class="font-outfit text-on-surface-variant group-hover:text-white/80 text-sm leading-relaxed mb-5 transition-colors">{s.desc}</p>
            <p class="font-space text-xs uppercase tracking-wider text-secondary group-hover:text-white/70 transition-colors">{s.timeline}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-24 bg-tertiary" aria-labelledby="how-heading">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="font-space text-xs font-semibold uppercase tracking-[0.25em] text-secondary-fixed mb-4 block">The Process</span>
        <h2 id="how-heading" class="font-fraunces font-bold text-white text-4xl md:text-5xl leading-tight">
          From Conversation to Production in Weeks
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        {[
          { step: '01', title: 'Discovery', desc: '30-minute call to understand your business, data, and goals. No technical jargon.' },
          { step: '02', title: 'Design', desc: 'We design the solution architecture and show you exactly how it will work.' },
          { step: '03', title: 'Deploy', desc: 'We build, test, and deploy. You review and approve before going live.' },
          { step: '04', title: 'Maintain', desc: 'Ongoing monitoring, updates, and improvements. You focus on your business.' },
        ].map((item, i) => (
          <div class="relative">
            {i < 3 && (
              <div class="hidden md:block absolute top-8 left-[60%] w-[80%] h-px bg-white/20" aria-hidden="true"></div>
            )}
            <p class="font-space text-xs font-semibold text-secondary-fixed mb-4">{item.step}</p>
            <h3 class="font-fraunces font-semibold text-white text-xl mb-3">{item.title}</h3>
            <p class="font-outfit text-white/70 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-primary" aria-labelledby="packaged-cta">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <h2 id="packaged-cta" class="font-fraunces font-bold text-white text-4xl md:text-5xl leading-tight mb-6">
        Start with a Free Consultation
      </h2>
      <p class="font-outfit font-light text-white/80 text-lg md:text-xl max-w-xl mx-auto mb-10 leading-relaxed">
        No commitment required. We'll tell you honestly whether Packaged AI is the right fit for your business — and if not, we'll point you in the right direction.
      </p>
      <Button href="/contact" label="Book Your Free Call" icon={true} />
    </div>
  </section>
</BaseLayout>
