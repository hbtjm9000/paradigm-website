---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/ContactForm.astro';

const features = [
  {
    title: 'AI Strategy Workshop',
    description: 'A comprehensive assessment of your business and identification of high-impact AI opportunities.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />`,
  },
  {
    title: 'Custom AI Integration',
    description: 'We implement AI solutions tailored to your specific workflows and business processes.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />`,
  },
  {
    title: 'Team Training',
    description: 'Hands-on training to ensure your team can effectively use and manage AI tools.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />`,
  },
  {
    title: 'Ongoing Support',
    description: 'SLA-backed support and optimization to ensure continued AI success.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />`,
  },
];

const deliverables = [
  'AI Opportunity Assessment Report',
  'Custom Implementation Roadmap',
  'Integrated AI Solutions (up to 3 workflows)',
  'Staff Training Program (up to 10 participants)',
  '30-Day Post-Implementation Support',
  'Documentation and User Guides',
];
---

<BaseLayout title="Packaged AI Solutions" description="AI integration made simple for Caribbean businesses. Our packaged AI solution includes strategy, implementation, training, and ongoing support.">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-secondary via-secondary to-primary/50 text-white py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <span class="inline-block bg-primary/20 text-primary px-4 py-1 rounded-full text-sm font-semibold mb-6">
          Limited Time Offer
        </span>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-6">
          Packaged AI Solutions for Caribbean Businesses
        </h1>
        <p class="text-xl text-gray-300 mb-10 max-w-2xl mx-auto">
          Everything you need to leverage AI in your business. Strategy, implementation, training, and support—all in one package.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/contact" class="btn-primary bg-primary text-white text-lg px-8 py-4">
            Get Started Today
          </a>
          <a href="#details" class="btn-outline text-white border-white hover:bg-white hover:text-secondary text-lg px-8 py-4">
            Learn More
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section id="details" class="py-16 lg:py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-secondary mb-4">What's Included</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          A complete package to bring AI into your business operations.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-16">
        {features.map((feature) => (
          <div class="bg-white rounded-xl p-6 shadow-md">
            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" set:html={feature.icon} />
            </div>
            <h3 class="text-lg font-bold text-secondary mb-2">{feature.title}</h3>
            <p class="text-gray-600">{feature.description}</p>
          </div>
        ))}
      </div>
      
      <!-- Deliverables -->
      <div class="bg-white rounded-2xl shadow-xl p-8 lg:p-12 max-w-4xl mx-auto">
        <h3 class="text-2xl font-bold text-secondary mb-6 text-center">Package Deliverables</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {deliverables.map((item) => (
            <div class="flex items-center space-x-3">
              <svg class="h-5 w-5 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-secondary mb-4">Investment</h2>
      <p class="text-lg text-gray-600 mb-8">
        A complete AI solution at a fixed price. No surprises.
      </p>
      <div class="bg-gradient-to-br from-primary to-primary/80 text-white rounded-2xl p-8 lg:p-12 shadow-2xl">
        <div class="text-5xl lg:text-6xl font-bold mb-2">$4,999</div>
        <div class="text-xl text-white/80 mb-8">One-time investment</div>
        <a href="/contact" class="btn-secondary bg-white text-primary hover:bg-gray-100 text-lg px-8 py-4 inline-block">
          Book Your Consultation
        </a>
      </div>
      <p class="text-sm text-gray-500 mt-6">
        Payment plans available. Satisfaction guaranteed.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-24 bg-secondary text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold mb-6">Ready to Bring AI to Your Business?</h2>
      <p class="text-xl text-gray-300 mb-10 max-w-2xl mx-auto">
        Book a consultation with our CEO and discover how Packaged AI can transform your operations.
      </p>
      <div class="max-w-2xl mx-auto">
        <ContactForm title="Get Started with Packaged AI" />
      </div>
    </div>
  </section>
</BaseLayout>
