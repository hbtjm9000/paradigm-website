---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you are looking for could not be found.">
  <section class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center">
      <div class="text-9xl font-bold text-primary/20 mb-4">404</div>
      <h1 class="text-3xl font-bold text-secondary mb-4">Page Not Found</h1>
      <p class="text-gray-600 mb-8">Sorry, the page you are looking for does not exist or has been moved.</p>
      <a href="/" class="btn-primary">Go Home</a>
    </div>
  </section>
</BaseLayout>
