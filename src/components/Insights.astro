---
interface Article {
  category: string;
  title: string;
  excerpt: string;
  image: string;
  link: string;
  featured?: boolean;
}

const articles: Article[] = [
  {
    category: "Systems Engineering",
    title: "Cloud Arrays & Edge Logic: Powering the Modern Economy",
    excerpt: "Examining the deployment of integrated cloud computing units in enterprise facilities across the technology landscape.",
    image: "/images/cloud-engineering.jpg",
    link: "/insights/cloud-arrays-edge-logic",
    featured: true
  },
  {
    category: "Security Protocol",
    title: "The Zero Trust Protocol",
    excerpt: "Technical audit of enterprise security architecture and its impact on regulated industries.",
    image: "/images/security-protocol.jpg",
    link: "/insights/zero-trust-protocol"
  },
  {
    category: "White Paper",
    title: "Privacy in the Public Square",
    excerpt: "A philosophical dive into biometric data collection and civil liberties within the enterprise framework.",
    image: "/images/privacy-paper.jpg",
    link: "/insights/privacy-public-square"
  },
  {
    category: "Event Recap",
    title: "The Paradigm Summit 2024",
    excerpt: "Key takeaways from the gathering of the top 100 technical leads from the enterprise technology landscape.",
    image: "/images/summit-event.jpg",
    link: "/insights/paradigm-summit-2024"
  }
];

const featuredArticle = articles.find(a => a.featured);
const regularArticles = articles.filter(a => !a.featured);
---

<section class="py-32 bg-surface">
  <div class="max-w-7xl mx-auto px-12">
    <!-- Section Header -->
    <h2 class="font-serif text-4xl mb-16 italic border-b-2 border-primary w-fit pb-2">
      Latest Documentation
    </h2>

    <!-- Bento Grid -->
    <div class="grid grid-cols-12 gap-8">

      <!-- Featured Article - Large Card -->
      {featuredArticle && (
        <article class="col-span-12 lg:col-span-8 bg-surface-container relative group overflow-hidden">
          <a href={featuredArticle.link} class="flex flex-col md:flex-row h-full">
            <div class="w-full md:w-1/2 overflow-hidden">
              <img
                src={featuredArticle.image}
                alt={featuredArticle.title}
                class="h-full w-full object-cover group-hover:scale-110 transition-transform duration-700"
                width="800" height="500"
                loading="lazy"
              />
            </div>
            <div class="w-full md:w-1/2 p-10 flex flex-col justify-between">
              <div>
                <span class="font-body text-[10px] uppercase tracking-widest text-primary mb-4 block">{featuredArticle.category}</span>
                <h3 class="font-serif text-3xl mb-4 leading-tight">{featuredArticle.title}</h3>
                <p class="font-body text-on-surface-variant text-sm line-clamp-3 mb-6">{featuredArticle.excerpt}</p>
              </div>
              <span class="font-body text-xs uppercase font-bold tracking-widest flex items-center gap-2 group-hover:gap-3 transition-all">
                Read Specification
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </div>
          </a>
        </article>
      )}

      <!-- Dark Technical Card -->
      <article class="col-span-12 lg:col-span-4 bg-slate-900 p-10 flex flex-col justify-between text-white">
        <div>
          <div class="w-12 h-12 bg-secondary flex items-center justify-center mb-8">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
            </svg>
          </div>
          <h3 class="font-serif text-2xl mb-4">The Nassau Protocol</h3>
          <p class="font-body text-slate-400 text-sm leading-relaxed">Technical audit of the region's first sovereign data center and its impact on regional latency.</p>
        </div>
        <div class="pt-8 border-t border-white/10">
          <div class="flex justify-between items-center text-[10px] font-body uppercase tracking-tighter text-secondary-fixed">
            <span>Status: Published</span>
            <span>Rev: 4.02</span>
          </div>
        </div>
      </article>

      <!-- Secondary Articles -->
      <div class="col-span-12 lg:col-span-4 flex flex-col gap-8">
        {regularArticles.slice(0, 2).map((article) => (
          <article class="group">
            <span class="font-body text-[10px] uppercase tracking-widest text-primary mb-4 block">{article.category}</span>
            <a href={article.link}>
              <h3 class="font-serif text-2xl mb-4">{article.title}</h3>
            </a>
            <p class="font-body text-on-surface-variant text-sm mb-8">{article.excerpt}</p>
            <img
              src={article.image}
              alt={article.title}
              class="w-full h-40 object-cover grayscale brightness-50"
              width="400" height="160"
              loading="lazy"
            />
          </article>
        ))}
      </div>

      <!-- Event Recap Card -->
      <article class="col-span-12 lg:col-span-8 bg-white border border-outline-variant/20 p-10 flex flex-col md:flex-row gap-8 items-center">
        <div class="w-full md:w-1/3">
          <img
            src="/images/summit-event.jpg"
            alt="Paradigm Summit 2024"
            class="w-full h-48 object-cover"
            width="300" height="192"
            loading="lazy"
          />
        </div>
        <div class="w-full md:w-2/3">
          <span class="font-body text-[10px] uppercase tracking-widest text-secondary mb-4 block">Event Recap</span>
          <h3 class="font-serif text-3xl mb-4">The Paradigm Summit 2024</h3>
          <p class="font-body text-on-surface-variant text-sm mb-6">Key takeaways from the gathering of the top 100 technical leads from the enterprise technology landscape.</p>
          <span class="border border-secondary text-secondary font-body text-xs uppercase px-6 py-2 hover:bg-secondary hover:text-white transition-all inline-block cursor-pointer">
            View Gallery
          </span>
        </div>
      </article>
    </div>
  </div>
</section>
