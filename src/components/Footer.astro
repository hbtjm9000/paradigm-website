---
const currentYear = new Date().getFullYear();

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/landings/element', label: 'Elements' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const legalLinks = [
  { href: '/privacy', label: 'Privacy Policy' },
  { href: '/terms', label: 'Terms of Service' },
];
---

<footer class="bg-surface border-t border-on-surface/10">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
      
      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-5" aria-label="Paradigm IT Services home">
          <img 
            src="/assets/logos/Paradigm IT Services Logo 1.svg" 
            alt="Paradigm IT Services" 
            class="h-10 w-auto"
            loading="lazy"
          />
        </a>
        <p class="font-fraunces italic text-on-surface-variant text-base leading-relaxed mb-6">
          Engineering the Next Paradigm.
        </p>
        <p class="font-outfit text-on-surface-variant/70 text-sm leading-relaxed">
          IT solutions for Caribbean businesses — founded in Kingston, Jamaica.
        </p>
      </div>

      <!-- Navigation Column -->
      <div>
        <h3 class="font-space text-xs font-semibold uppercase tracking-[0.2em] text-on-surface mb-6">
          Navigation
        </h3>
        <ul class="space-y-3" role="list">
          {navLinks.map(link => (
            <li>
              <a 
                href={link.href}
                class="font-fraunces italic text-on-surface-variant hover:text-secondary transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Connect Column -->
      <div>
        <h3 class="font-space text-xs font-semibold uppercase tracking-[0.2em] text-on-surface mb-6">
          Connect
        </h3>
        <ul class="space-y-4" role="list">
          <li>
            <a 
              href="mailto:hello@serviceparadigm.com"
              class="flex items-center gap-2 font-outfit text-on-surface-variant hover:text-secondary transition-colors duration-200 text-sm"
            >
              <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              hello@serviceparadigm.com
            </a>
          </li>
          <li>
            <a 
              href="tel:+18765550199"
              class="flex items-center gap-2 font-outfit text-on-surface-variant hover:text-secondary transition-colors duration-200 text-sm"
            >
              <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              +1 (876) 555-0199
            </a>
          </li>
          <li>
            <span class="flex items-center gap-2 font-outfit text-on-surface-variant text-sm">
              <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              Kingston, Jamaica
            </span>
          </li>
          <li>
            <a 
              href="https://linkedin.com/company/paradigm-it-services"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 font-outfit text-on-surface-variant hover:text-secondary transition-colors duration-200 text-sm"
              aria-label="LinkedIn"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal Column -->
      <div>
        <h3 class="font-space text-xs font-semibold uppercase tracking-[0.2em] text-on-surface mb-6">
          Legal
        </h3>
        <ul class="space-y-3" role="list">
          {legalLinks.map(link => (
            <li>
              <a 
                href={link.href}
                class="font-outfit text-on-surface-variant hover:text-secondary transition-colors duration-200 text-sm"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-on-surface/10">
      <p class="font-space text-xs uppercase tracking-[0.2em] text-on-surface-variant/60 text-center">
        &copy; {currentYear} Paradigm IT Services Ltd. All rights reserved.
      </p>
    </div>
  </div>
</footer>
