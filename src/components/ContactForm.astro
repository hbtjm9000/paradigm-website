---
const businessPhases = [
  { value: '', label: 'Select your phase' },
  { value: 'startup', label: 'Just Starting Out' },
  { value: 'growing', label: 'Growing & Scaling' },
  { value: 'optimizing', label: 'Optimizing Operations' },
  { value: 'transforming', label: 'Digital Transformation' },
];
---

<section class="w-full" aria-label="Contact form">
  <form 
    id="contact-form" 
    class="space-y-6" 
    novalidate
    aria-label="Contact Paradigm IT Services"
  >
    <!-- Honeypot (spam prevention) -->
    <input 
      type="text" 
      name="website" 
      tabindex="-1" 
      autocomplete="off"
      class="hidden"
      aria-hidden="true"
    />

    <!-- Name -->
    <div class="form-field">
      <label for="name" class="label">
        Full Name <span class="text-error" aria-label="required">*</span>
      </label>
      <input 
        type="text" 
        id="name" 
        name="name" 
        required
        autocomplete="name"
        class="input-underline"
        placeholder="Marcus Brown"
        aria-required="true"
      />
      <span class="field-error hidden" id="name-error" role="alert"></span>
    </div>

    <!-- Email -->
    <div class="form-field">
      <label for="email" class="label">
        Email Address <span class="text-error" aria-label="required">*</span>
      </label>
      <input 
        type="email" 
        id="email" 
        name="email" 
        required
        autocomplete="email"
        class="input-underline"
        placeholder="marcus@yourbusiness.com"
        aria-required="true"
      />
      <span class="field-error hidden" id="email-error" role="alert"></span>
    </div>

    <!-- Phone -->
    <div class="form-field">
      <label for="phone" class="label">Phone Number</label>
      <input 
        type="tel" 
        id="phone" 
        name="phone" 
        autocomplete="tel"
        class="input-underline"
        placeholder="+1 (876) 555-0199"
      />
    </div>

    <!-- Business Phase -->
    <div class="form-field">
      <label for="business_phase" class="label">
        Business Phase <span class="text-error" aria-label="required">*</span>
      </label>
      <div class="select-wrapper">
        <select 
          id="business_phase" 
          name="business_phase" 
          required
          class="input-underline select-underline"
          aria-required="true"
        >
          {businessPhases.map(opt => (
            <option value={opt.value}>{opt.label}</option>
          ))}
        </select>
        <svg class="select-arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M6 9l6 6 6-6"/>
        </svg>
      </div>
      <span class="field-error hidden" id="phase-error" role="alert"></span>
    </div>

    <!-- Biggest Impact -->
    <div class="form-field">
      <label for="biggest_impact" class="label">
        What would have the biggest impact? <span class="text-error" aria-label="required">*</span>
      </label>
      <textarea 
        id="biggest_impact" 
        name="biggest_impact" 
        rows="4" 
        required
        class="input-underline resize-none"
        placeholder="Tell us about your biggest IT challenge or goal..."
        aria-required="true"
      ></textarea>
      <span class="field-error hidden" id="impact-error" role="alert"></span>
    </div>

    <!-- Submit -->
    <div class="pt-2">
      <button 
        type="submit" 
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-primary text-white uppercase text-sm font-space font-semibold tracking-widest px-8 py-4 hover:bg-secondary transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
      >
        <span id="submit-text">Send Message</span>
        <svg id="submit-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </button>
    </div>
  </form>

  <!-- Success message -->
  <div id="form-success" class="hidden mt-6 p-6 border-l-4 border-secondary bg-secondary/5" role="status" aria-live="polite">
    <p class="font-fraunces font-semibold text-secondary text-lg mb-2">Message received.</p>
    <p class="font-outfit text-on-surface-variant text-sm">
      We typically respond within one business day. Looking forward to connecting.
    </p>
  </div>

  <!-- Error message -->
  <div id="form-error" class="hidden mt-6 p-6 border-l-4 border-error bg-error/5" role="alert" aria-live="assertive">
    <p class="font-outfit text-error text-sm">
      Something went wrong. Please try again or email us directly at 
      <a href="mailto:hello@serviceparadigm.com" class="underline">hello@serviceparadigm.com</a>.
    </p>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successEl = document.getElementById('form-success');
  const errorEl = document.getElementById('form-error');
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;
  const submitText = document.getElementById('submit-text');

  function showError(fieldId: string, message: string) {
    const errorSpan = document.getElementById(`${fieldId}-error`);
    const input = document.getElementById(fieldId) as HTMLInputElement;
    if (errorSpan) {
      errorSpan.textContent = message;
      errorSpan.classList.remove('hidden');
    }
    if (input) input.classList.add('border-error');
  }

  function clearErrors() {
    document.querySelectorAll('.field-error').forEach(el => el.classList.add('hidden'));
    document.querySelectorAll('.border-error').forEach(el => el.classList.remove('border-error'));
  }

  function validate(data: FormData): boolean {
    clearErrors();
    let valid = true;
    if (!String(data.get('name')).trim()) { showError('name', 'Please enter your name.'); valid = false; }
    const email = String(data.get('email')).trim();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showError('email', 'Please enter a valid email.'); valid = false; }
    if (!String(data.get('business_phase'))) { showError('phase', 'Please select a business phase.'); valid = false; }
    if (!String(data.get('biggest_impact')).trim()) { showError('impact', 'Please tell us about your biggest impact.'); valid = false; }
    return valid;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl?.classList.add('hidden');
    const data = new FormData(form);
    
    // Honeypot check
    if (data.get('website')) return;
    
    if (!validate(data)) return;
    
    if (submitBtn) submitBtn.disabled = true;
    if (submitText) submitText.textContent = 'Sending...';
    
    try {
      // Form submission handler — wire to Netlify Forms, Formspree, or custom endpoint.
      // Example Netlify: add netlify attribute to <form>.
      // Example Formspree: POST to https://formspree.io/f/YOUR_ID.
      await new Promise(resolve => setTimeout(resolve, 800));
      form.classList.add('hidden');
      successEl?.classList.remove('hidden');
    } catch {
      errorEl?.classList.remove('hidden');
      if (submitBtn) submitBtn.disabled = false;
      if (submitText) submitText.textContent = 'Send Message';
    }
  });
</script>
