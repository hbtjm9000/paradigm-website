---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/landings/element', label: 'Elements' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const pathname = Astro.url.pathname;
---

<header class="fixed top-0 z-50 w-full bg-slate-900/80 backdrop-blur-xl border-b border-white/10">
  <nav class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between" aria-label="Main navigation">
    <!-- Logo + Brand -->
    <a href="/" class="flex items-center gap-3 group" aria-label="Paradigm IT Services home">
      <img 
        src="/assets/logos/logo-white.svg" 
        alt="Paradigm IT Services" 
        class="h-9 w-auto"
        width="160"
        height="36"
        loading="eager"
      />
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden md:flex items-center gap-8" role="list">
      {navLinks.map(link => (
        <li>
          <a 
            href={link.href}
            class:list={[
              'font-fraunces italic text-sm tracking-wide transition-colors duration-200',
              pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href))
                ? 'text-white'
                : 'text-white/60 hover:text-white'
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Desktop CTA -->
    <a 
      href="/contact" 
      class="hidden md:inline-flex items-center gap-2 bg-primary text-white uppercase text-xs font-space font-semibold tracking-widest px-6 py-2.5 hover:bg-secondary transition-colors duration-200"
    >
      Get Started
    </a>

    <!-- Mobile Hamburger -->
    <button 
      id="mobile-menu-toggle" 
      class="md:hidden flex flex-col gap-1.5 p-2 text-white"
      aria-label="Toggle mobile menu"
      aria-expanded="false"
    >
      <span class="block w-5 h-0.5 bg-white/80 transition-all duration-200" id="bar1"></span>
      <span class="block w-5 h-0.5 bg-white/80 transition-all duration-200" id="bar2"></span>
      <span class="block w-3.5 h-0.5 bg-white/80 transition-all duration-200" id="bar3"></span>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div 
    id="mobile-menu" 
    class="md:hidden hidden bg-slate-900/95 border-t border-white/10"
    aria-hidden="true"
  >
    <ul class="flex flex-col px-6 py-4 gap-4" role="list">
      {navLinks.map(link => (
        <li>
          <a 
            href={link.href}
            class:list={[
              'block font-fraunces italic text-base tracking-wide py-2',
              pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href))
                ? 'text-white'
                : 'text-white/60'
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2 border-t border-white/10">
        <a 
          href="/contact"
          class="inline-flex items-center bg-primary text-white uppercase text-xs font-space font-semibold tracking-widest px-6 py-3 hover:bg-secondary transition-colors duration-200"
        >
          Get Started
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');
  let isOpen = false;

  toggle?.addEventListener('click', () => {
    isOpen = !isOpen;
    menu?.classList.toggle('hidden', !isOpen);
    menu?.setAttribute('aria-hidden', String(!isOpen));
    toggle?.setAttribute('aria-expanded', String(isOpen));
    if (bar1) bar1.style.transform = isOpen ? 'rotate(45deg) translate(4px, 4px)' : '';
    if (bar2) bar2.style.opacity = isOpen ? '0' : '1';
    if (bar3) {
      bar3.style.width = isOpen ? '1.25rem' : '0.875rem';
      bar3.style.transform = isOpen ? 'rotate(-45deg) translate(4px, -4px)' : '';
    }
  });
</script>
