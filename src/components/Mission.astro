---
---

<section class="bg-surface py-20 lg:py-32 relative">
  <div class="max-w-7xl mx-auto px-12">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">

      <!-- Image Column -->
      <div class="w-full lg:w-1/2 relative">
        <div class="absolute -top-12 -left-12 w-48 h-48 bg-secondary-fixed-dim/10 z-0"></div>
        <img
          src="/images/strategic-leader.jpg"
          alt="Strategic technology leadership"
          class="w-full h-[600px] object-cover grayscale hover:grayscale-0 transition-all duration-700 relative z-10"
          width="600" height="750"
        />
        <!-- Quote overlay -->
        <div class="absolute bottom-6 right-6 bg-slate-900 text-white p-8 z-20 max-w-xs">
          <span class="font-body text-[10px] uppercase tracking-widest text-secondary-fixed mb-2 block">Executive Highlight</span>
          <p class="font-serif text-xl italic mb-4">"The network is the primary asset of the emerging tech hub."</p>
          <p class="font-body text-xs opacity-60">Director of Systems, Kingston Protocol</p>
        </div>
      </div>

      <!-- Content Column -->
      <div class="w-full lg:w-1/2">
        <!-- Section Label -->
        <span class="font-body text-xs tracking-[0.2em] text-primary uppercase">Our Approach</span>

        <!-- Headline -->
        <h2 class="font-serif text-5xl lg:text-6xl text-on-surface mb-8 tracking-tight">
          Bridging the Latency between Vision and
          <span class="italic text-primary"> Execution.</span>
        </h2>

        <!-- Description -->
        <div class="space-y-8 font-body text-on-surface-variant text-lg leading-relaxed">
          <p>
            Our consulting focus centers on the intersection of legacy
            infrastructure and the decentralized future. We provide the technical
            blueprints necessary for an architecture-first technology ecosystem.
          </p>

          <!-- Stats -->
          <div class="grid grid-cols-2 gap-4 pt-8">
            <div class="border-t border-outline-variant/30 pt-4">
              <span class="block font-body text-3xl font-bold text-primary">84%</span>
              <span class="font-body text-xs uppercase opacity-60">Connectivity Growth</span>
            </div>
            <div class="border-t border-outline-variant/30 pt-4">
              <span class="block font-body text-3xl font-bold text-primary">12.5 TB</span>
              <span class="font-body text-xs uppercase opacity-60">Daily Data Ingress</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
