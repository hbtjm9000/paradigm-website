---
---

<section class="bg-surface py-20 lg:py-32">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      
      <!-- Image Column -->
      <div class="relative">
        <div class="relative aspect-[4/5] bg-surface-container overflow-hidden">
          <img 
            src="/images/strategic-leader.jpg" 
            alt="Strategic technology leadership"
            class="w-full h-full object-cover"
          />
          <!-- Quote overlay -->
          <div class="absolute bottom-0 left-0 right-0 bg-tertiary/95 p-6">
            <p class="font-serif text-lg italic text-white leading-relaxed">
              "The network is the primary asset of the converging tech hub."
            </p>
            <p class="font-sans text-xs text-white/60 mt-3 tracking-wide uppercase">
              Director of Systems, Paradigm IT
            </p>
          </div>
        </div>
      </div>

      <!-- Content Column -->
      <div>
        <!-- Section Label -->
        <span class="font-sans text-xs tracking-[0.2em] text-primary uppercase">Our Approach</span>
        
        <!-- Headline -->
        <h2 class="font-serif text-4xl lg:text-5xl text-on-surface mt-4 leading-[1.1] text-balance">
          Bridging the Latency between Vision and
          <span class="italic text-primary"> Execution.</span>
        </h2>

        <!-- Description -->
        <p class="font-body text-on-surface-variant mt-8 leading-relaxed text-lg">
          Our consulting focus centers on the intersection of legacy 
          infrastructure and the decentralized future. We provide the technical 
          blueprints necessary for an architecture-first technology ecosystem.
        </p>

        <!-- Stats -->
        <div class="grid grid-cols-2 gap-8 mt-12">
          <div>
            <span class="font-serif text-5xl lg:text-6xl text-on-surface">84%</span>
            <p class="font-sans text-xs tracking-wide text-on-surface-variant mt-2 uppercase">Connectivity Growth</p>
          </div>
          <div>
            <span class="font-serif text-5xl lg:text-6xl text-on-surface">12.5 <span class="text-3xl">TB</span></span>
            <p class="font-sans text-xs tracking-wide text-on-surface-variant mt-2 uppercase">Daily Data Managed</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
