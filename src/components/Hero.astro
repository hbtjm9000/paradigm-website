---
---

<section class="bg-tertiary text-on-tertiary relative overflow-hidden">
  <!-- Subtle tech pattern overlay -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: url('/pattern.svg'); background-repeat: repeat;"></div>
  </div>
  
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 lg:py-32 relative z-10">
    <!-- Label -->
    <div class="mb-6">
      <span class="font-sans text-xs tracking-[0.2em] text-secondary-fixed-dim uppercase">Engineering the Next Paradigm</span>
    </div>

    <!-- Main Headline -->
    <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl text-white leading-[1.05] max-w-4xl text-balance">
      The Digital
      <br />
      Infrastructure
      <br />
      of <span class="italic text-secondary-fixed-dim relative">
        Tomorrow.
        <svg class="absolute -bottom-2 left-0 w-full h-3" viewBox="0 0 200 12" preserveAspectRatio="none">
          <path d="M0 6 Q 50 0, 100 6 T 200 6" stroke="currentColor" stroke-width="2" fill="none" class="text-secondary-fixed-dim"/>
        </svg>
      </span>
    </h1>

    <!-- CTA Button -->
    <div class="mt-12">
      <a 
        href="/contact" 
        class="inline-flex items-center gap-2 bg-secondary text-on-secondary font-sans text-sm px-6 py-3 hover:bg-secondary-fixed-dim hover:text-tertiary transition-colors tracking-wide group"
      >
        <span>Start Your Transformation</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <!-- Subtext -->
    <p class="mt-10 max-w-xl text-white/70 font-body leading-relaxed">
      Architecting the future of enterprise technology through 
      AI strategy, secure infrastructure, and precision engineering.
    </p>
  </div>
</section>
