---
interface Props {
  title: string;
  description: string;
  icon?: string;
  href?: string;
  featured?: boolean;
}

const { title, description, icon, href = '/contact', featured = false } = Astro.props;

const defaultIcons: Record<string, string> = {
  'digital-transformation': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />`,
  'consulting': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />`,
  'managed-services': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />`,
};

const iconPath = icon ? defaultIcons[icon] || defaultIcons['consulting'] : defaultIcons['consulting'];
---

<article class:list={[
  'card group border border-gray-200',
  featured ? 'border-primary' : ''
]}>
  <div class="flex items-start space-x-4">
    <div class:list={[
      'p-3 flex-shrink-0 transition-all duration-300',
      featured ? 'bg-primary text-white' : 'bg-gray-100 text-primary group-hover:bg-primary group-hover:text-white'
    ]}>
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" set:html={iconPath} />
    </div>
    
    <div class="flex-1">
      <h3 class="text-xl font-display font-semibold text-secondary mb-2">{title}</h3>
      <p class="text-ink-muted mb-4">{description}</p>
      <a href={href} class="inline-flex items-center text-primary font-medium hover:text-secondary transition-colors">
        Learn more
        <svg class="h-4 w-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</article>
