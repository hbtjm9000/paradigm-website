---
interface Props {
  title?: string;
  description?: string;
}

const { title = 'Book a Meeting with Our CEO', description = 'Fill out the form below and we will get back to you within 24 hours.' } = Astro.props;

const businessPhases = [
  { value: '', label: 'Select your business phase' },
  { value: 'startup', label: 'Startup (0-1 years)' },
  { value: 'early', label: 'Early Growth (1-3 years)' },
  { value: 'established', label: 'Established (3-10 years)' },
  { value: 'enterprise', label: 'Enterprise (10+ years)' },
];
---

<section class="max-w-2xl mx-auto">
  <div class="bg-white p-8 border border-gray-200">
    <h2 class="text-2xl font-display font-semibold text-secondary mb-2">{title}</h2>
    <p class="text-ink-muted mb-8">{description}</p>
    
    <form id="contact-form" class="space-y-6" novalidate>
      <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />
      
      <div>
        <label for="name" class="block text-sm font-medium text-ink mb-2">
          Name <span class="text-red-500" aria-hidden="true">*</span>
          <span class="sr-only">(required)</span>
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          minlength="2"
          autocomplete="name"
          class="w-full px-0 py-3 bg-transparent border-b-2 border-gray-300 focus:border-primary focus:ring-0 transition-colors text-ink placeholder-ink-faded"
          placeholder="Your full name"
          aria-describedby="name-error"
        />
        <p id="name-error" class="mt-1 text-sm text-red-600 hidden" role="alert"></p>
      </div>
      
      <div>
        <label for="email" class="block text-sm font-medium text-ink mb-2">
          Email <span class="text-red-500" aria-hidden="true">*</span>
          <span class="sr-only">(required)</span>
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          class="w-full px-0 py-3 bg-transparent border-b-2 border-gray-300 focus:border-primary focus:ring-0 transition-colors text-ink placeholder-ink-faded"
          placeholder="you@yourbusiness.com"
          aria-describedby="email-error"
        />
        <p id="email-error" class="mt-1 text-sm text-red-600 hidden" role="alert"></p>
      </div>
      
      <div>
        <label for="phone" class="block text-sm font-medium text-ink mb-2">
          Phone <span class="text-ink-faded">(optional)</span>
        </label>
        <input
          type="tel"
          id="phone"
          name="phone"
          autocomplete="tel"
          class="w-full px-0 py-3 bg-transparent border-b-2 border-gray-300 focus:border-primary focus:ring-0 transition-colors text-ink placeholder-ink-faded"
          placeholder="+1 (876) 000-0000"
        />
      </div>
      
      <div>
        <label for="business_phase" class="block text-sm font-medium text-ink mb-2">
          Business Phase <span class="text-red-500" aria-hidden="true">*</span>
          <span class="sr-only">(required)</span>
        </label>
        <select
          id="business_phase"
          name="business_phase"
          required
          class="w-full px-0 py-3 bg-transparent border-b-2 border-gray-300 focus:border-primary focus:ring-0 transition-colors text-ink"
          aria-describedby="business_phase-error"
        >
          {businessPhases.map((phase) => (
            <option value={phase.value}>{phase.label}</option>
          ))}
        </select>
        <p id="business_phase-error" class="mt-1 text-sm text-red-600 hidden" role="alert"></p>
      </div>
      
      <div>
        <label for="biggest_impact" class="block text-sm font-medium text-ink mb-2">
          What would have the biggest impact for your business? <span class="text-red-500" aria-hidden="true">*</span>
          <span class="sr-only">(required)</span>
        </label>
        <textarea
          id="biggest_impact"
          name="biggest_impact"
          required
          minlength="10"
          rows="4"
          class="w-full px-0 py-3 bg-transparent border-b-2 border-gray-300 focus:border-primary focus:ring-0 transition-colors text-ink placeholder-ink-faded resize-none"
          placeholder="Tell us about your biggest challenges or goals..."
          aria-describedby="biggest_impact-error"
        ></textarea>
        <p id="biggest_impact-error" class="mt-1 text-sm text-red-600 hidden" role="alert"></p>
      </div>
      
      <div>
        <button type="submit" class="btn-primary w-full text-lg py-4">
          <span id="submit-text">Request Consultation</span>
          <span id="submit-loading" class="hidden">
            <svg class="animate-spin h-5 w-5 inline ml-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </span>
        </button>
      </div>
    </form>
    
    <div id="success-message" class="hidden text-center py-8">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-green-100 mb-4">
        <svg class="h-8 w-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h3 class="text-xl font-display font-semibold text-secondary mb-2">Thank You!</h3>
      <p class="text-ink-muted">We have received your request and will be in touch within 24 hours.</p>
    </div>
    
    <div id="error-message" class="hidden text-center py-8">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-red-100 mb-4">
        <svg class="h-8 w-8 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
      </div>
      <h3 class="text-xl font-display font-semibold text-secondary mb-2">Something went wrong</h3>
      <p class="text-ink-muted">Please try again or contact us directly at <a href="mailto:hello@serviceparadigm.com" class="text-primary hover:underline">hello@serviceparadigm.com</a></p>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitText = document.getElementById('submit-text');
  const submitLoading = document.getElementById('submit-loading');
  const successMessage = document.getElementById('success-message');
  const errorMessage = document.getElementById('error-message');
  
  function showError(fieldId: string, message: string) {
    const errorEl = document.getElementById(`${fieldId}-error`);
    const inputEl = document.getElementById(fieldId);
    if (errorEl && inputEl) {
      errorEl.textContent = message;
      errorEl.classList.remove('hidden');
      inputEl.classList.add('border-red-500');
      inputEl.setAttribute('aria-invalid', 'true');
    }
  }
  
  function clearErrors() {
    document.querySelectorAll('[id$="-error"]').forEach(el => el?.classList.add('hidden'));
    document.querySelectorAll('input, select, textarea').forEach(el => {
      el.classList.remove('border-red-500');
      el.removeAttribute('aria-invalid');
    });
  }
  
  function validateForm(data: FormData): boolean {
    clearErrors();
    let isValid = true;
    
    const name = data.get('name') as string;
    if (!name || name.trim().length < 2) {
      showError('name', 'Please enter your name (at least 2 characters)');
      isValid = false;
    }
    
    const email = data.get('email') as string;
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!email || !emailRegex.test(email)) {
      showError('email', 'Please enter a valid email address');
      isValid = false;
    }
    
    const businessPhase = data.get('business_phase') as string;
    if (!businessPhase) {
      showError('business_phase', 'Please select your business phase');
      isValid = false;
    }
    
    const biggestImpact = data.get('biggest_impact') as string;
    if (!biggestImpact || biggestImpact.trim().length < 10) {
      showError('biggest_impact', 'Please describe your biggest impact (at least 10 characters)');
      isValid = false;
    }
    
    return isValid;
  }
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const data = new FormData(form);
    
    if (data.get('_gotcha')) {
      return;
    }
    
    if (!validateForm(data)) {
      return;
    }
    
    submitText?.classList.add('hidden');
    submitLoading?.classList.remove('hidden');
    
    try {
      await new Promise(resolve => setTimeout(resolve, 1500));
      
      form.classList.add('hidden');
      successMessage?.classList.remove('hidden');
      
      if (typeof gtag !== 'undefined') {
        gtag('event', 'generate_lead', {
          event_category: 'engagement',
          event_label: 'contact_form'
        });
      }
    } catch (error) {
      form.classList.add('hidden');
      errorMessage?.classList.remove('hidden');
    } finally {
      submitText?.classList.remove('hidden');
      submitLoading?.classList.add('hidden');
    }
  });
</script>
