---
const quickLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/landings/element', label: 'Elements' },
  { href: '/about', label: 'About Us' },
  { href: '/contact', label: 'Contact' },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-tertiary text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <div class="lg:col-span-2">
        <div class="flex items-center space-x-3 mb-4">
          <svg class="h-10 w-10 text-primary" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="2"/>
            <path d="M12 20L20 12L28 20L20 28L12 20Z" fill="currentColor"/>
            <circle cx="20" cy="20" r="4" fill="white"/>
          </svg>
          <span class="font-bold text-xl">Paradigm IT Services</span>
        </div>
        <p class="text-gray-400 mb-6 max-w-md">
          Engineering the Next Paradigm. We help Caribbean businesses transform with innovative IT solutions, AI integration, and managed services.
        </p>
        <div class="flex space-x-4">
          <a href="https://linkedin.com/company/paradigm-it" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-primary transition-colors" aria-label="LinkedIn">
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>
      
      <div>
        <h3 class="font-bold text-lg mb-4">Quick Links</h3>
        <ul class="space-y-3">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-primary transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <div>
        <h3 class="font-bold text-lg mb-4">Contact</h3>
        <ul class="space-y-3 text-gray-400">
          <li class="flex items-start space-x-3">
            <svg class="h-5 w-5 mt-0.5 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Kingston, Jamaica</span>
          </li>
          <li class="flex items-start space-x-3">
            <svg class="h-5 w-5 mt-0.5 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:hello@serviceparadigm.com" class="hover:text-primary transition-colors">
              hello@serviceparadigm.com
            </a>
          </li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-white/10 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
      <p class="text-gray-500 text-sm">
        &copy; {currentYear} Paradigm IT Services. All rights reserved.
      </p>
      <div class="flex space-x-6 text-sm text-gray-500">
        <a href="/privacy" class="hover:text-primary transition-colors">Privacy Policy</a>
        <a href="/terms" class="hover:text-primary transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
