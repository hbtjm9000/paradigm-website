---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { getServices } from '../utils/content-loader';

const services = await getServices();
const featuredServices = services.slice(0, 3);

const stats = [
  { value: '50+', label: 'Caribbean Businesses Served' },
  { value: '10+', label: 'Years of Experience' },
  { value: '99.9%', label: 'Uptime Guarantee' },
];
---

<BaseLayout title="Home" description="Paradigm IT Services - Engineering the Next Paradigm. IT solutions, digital transformation, and AI integration for Caribbean businesses.">
  <Hero
    title="Engineering the Next Paradigm"
    description="<!-- TODO: Hal review -->"
    primaryCta={{ href: '/contact', label: 'Request Consultation' }}
    secondaryCta={{ href: '/services', label: 'Explore Services' }}
  />

  <section class="py-20 lg:py-28 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-display-md font-display font-bold text-secondary mb-4">What We Do</h2>
        <p class="text-xl text-ink-muted max-w-2xl mx-auto">
          From digital transformation to ongoing managed services, we provide comprehensive IT solutions tailored to your business needs.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {featuredServices.map((service) => (
          <ServiceCard
            title={service.title}
            description={service.description}
            icon={service.icon as string}
            href={`/services#${service.slug}`}
            featured={true}
          />
        ))}
      </div>
      
      <div class="text-center mt-12">
        <a href="/services" class="btn-secondary inline-flex items-center text-lg px-8 py-4">
          View All Services
          <svg class="inline h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-primary font-mono text-sm uppercase tracking-widest mb-4">About Paradigm IT</p>
          <h2 class="text-display-sm font-display font-bold text-secondary mb-6">
            Rooted in Jamaica, Serving the Caribbean
          </h2>
          <p class="text-lg text-ink-muted mb-6">
            Founded in Kingston, Jamaica, Paradigm IT Services understands the unique challenges and opportunities facing Caribbean businesses. We combine global best practices with local expertise to deliver IT solutions that work for our region.
          </p>
          <p class="text-lg text-ink-muted mb-8">
            Whether you are a startup in Kingston or an established enterprise across the Caribbean, we provide the technical expertise and personal service you need to succeed in today's digital landscape.
          </p>
          <a href="/about" class="btn-secondary inline-block px-8 py-4">
            Learn More About Us
          </a>
        </div>
        <div class="bg-gray-800 p-12 lg:p-16">
          <div class="grid grid-cols-1 gap-12">
            {stats.map((stat) => (
              <div class="text-center lg:text-left">
                <div class="text-5xl lg:text-6xl font-display font-bold text-primary mb-2">{stat.value}</div>
                <div class="text-ink-muted text-lg">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28 bg-tertiary text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-display-md font-display font-bold mb-4">Why Choose Paradigm IT?</h2>
        <p class="text-xl text-gray-400 max-w-2xl mx-auto">
          We combine technical expertise with Caribbean business understanding to deliver results that matter.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-primary/20 mb-6">
            <svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-xl font-display font-semibold mb-3">Enterprise Security</h3>
          <p class="text-gray-400">Bank-grade security protocols to protect your business data.</p>
        </div>
        
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-primary/20 mb-6">
            <svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-display font-semibold mb-3">Fast Response</h3>
          <p class="text-gray-400">SLA-backed support with guaranteed response times.</p>
        </div>
        
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-primary/20 mb-6">
            <svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-display font-semibold mb-3">Caribbean Focus</h3>
          <p class="text-gray-400">We understand regional challenges and opportunities.</p>
        </div>
        
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-primary/20 mb-6">
            <svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-display font-semibold mb-3">Dedicated Team</h3>
          <p class="text-gray-400">Personal attention from experienced IT professionals.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28 bg-gradient-to-br from-primary to-primary/80 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-display-sm font-display font-bold mb-6">Ready to Transform Your Business?</h2>
      <p class="text-xl text-white/90 mb-10 max-w-2xl mx-auto">
        Book a consultation with our CEO and discover how Paradigm IT can help you achieve your technology goals.
      </p>
      <a href="/contact" class="btn-secondary inline-block text-lg px-8 py-4">
        Book Your Consultation
      </a>
    </div>
  </section>
</BaseLayout>
