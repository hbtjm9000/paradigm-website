---
import BaseLayout from '../layouts/BaseLayout.astro';

const values = [
  {
    title: 'Innovation',
    description: 'We embrace cutting-edge technology while staying grounded in practical solutions.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />`,
  },
  {
    title: 'Integrity',
    description: 'Honest communication, transparent pricing, and doing what we say we will do.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />`,
  },
  {
    title: 'Excellence',
    description: 'We deliver high-quality work and continuously improve our skills and processes.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />`,
  },
  {
    title: 'Partnership',
    description: 'We view our clients as partners and invest in their long-term success.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />`,
  },
];

const milestones = [
  { year: '2015', event: 'Founded in Kingston, Jamaica' },
  { year: '2018', event: 'Expanded to serve Caribbean region' },
  { year: '2020', event: 'Launched managed services division' },
  { year: '2023', event: 'AI practice established' },
  { year: '2026', event: 'Serving 50+ businesses across the Caribbean' },
];
---

<BaseLayout title="About Us" description="Learn about Paradigm IT Services - your trusted IT partner in Jamaica and the Caribbean. Rooted in Kingston, serving businesses across the region.">
  <section class="bg-gradient-to-br from-tertiary via-secondary/20 to-tertiary text-white py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-display-lg font-display font-bold mb-6">About Paradigm IT</h1>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto">
        Engineering the Next Paradigm for Caribbean businesses through innovative technology solutions.
      </p>
    </div>
  </section>

  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-primary font-mono text-sm uppercase tracking-widest mb-4">Our Story</p>
          <h2 class="text-display-sm font-display font-bold text-secondary mb-6">
            From Kingston to the Caribbean
          </h2>
          <div class="space-y-4 text-lg text-ink-muted">
            <p>
              Founded in Kingston, Jamaica, Paradigm IT Services was born from a simple observation: Caribbean businesses deserve world-class technology solutions delivered with local understanding and personal service.
            </p>
            <p>
              Over the past decade, we have grown from a small team of passionate technologists to a trusted partner for businesses across Jamaica and the wider Caribbean. Our approach combines deep technical expertise with a genuine understanding of the unique challenges facing our region.
            </p>
            <p>
              Today, we help businesses of all sizes transform their operations through digital innovation, AI integration, and reliable managed services. Our commitment remains the same: delivering results that matter while building lasting partnerships.
            </p>
          </div>
        </div>
        <div class="bg-gray-800 p-8 lg:p-12">
          <blockquote class="text-xl italic text-white mb-6 font-display">
            "We do not just solve technical problems. We understand the Caribbean business context and deliver solutions that actually work for our clients."
          </blockquote>
          <div class="flex items-center space-x-4">
            <div class="bg-primary/20 p-3">
              <svg class="h-10 w-10 text-primary" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="2"/>
                <path d="M12 20L20 12L28 20L20 28L12 20Z" fill="currentColor"/>
                <circle cx="20" cy="20" r="4" fill="white"/>
              </svg>
            </div>
            <div>
              <div class="font-bold text-white">CEO</div>
              <div class="text-gray-400">Paradigm IT Services</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28 bg-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-display-md font-display font-bold text-white mb-4">Founder & Leadership</h2>
        <p class="text-xl text-gray-400 max-w-2xl mx-auto">
          <!-- TODO: Hal photo -->
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="bg-white p-8 border border-gray-200">
          <div class="flex items-start space-x-4">
            <div class="p-3 bg-primary/10 text-primary flex-shrink-0">
              <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div>
              <h3 class="text-2xl font-display font-semibold text-secondary mb-3">Our Mission</h3>
              <p class="text-ink-muted text-lg">
                To empower Caribbean businesses with innovative technology solutions that drive growth, efficiency, and competitive advantage while delivering exceptional service and lasting partnerships.
              </p>
            </div>
          </div>
        </div>
        
        <div class="bg-white p-8 border border-gray-200">
          <div class="flex items-start space-x-4">
            <div class="p-3 bg-primary/10 text-primary flex-shrink-0">
              <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            </div>
            <div>
              <h3 class="text-2xl font-display font-semibold text-secondary mb-3">Our Vision</h3>
              <p class="text-ink-muted text-lg">
                To be the leading technology partner for businesses across the Caribbean, recognized for innovation, reliability, and our commitment to regional economic development through technology.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-display-md font-display font-bold text-secondary mb-4">Our Journey</h2>
        <p class="text-xl text-ink-muted max-w-2xl mx-auto">
          A decade of growth, learning, and delivering results for Caribbean businesses.
        </p>
      </div>
      
      <div class="relative">
        <div class="absolute left-1/2 transform -translate-x-1/2 h-full w-px bg-primary/30"></div>
        <div class="space-y-12">
          {milestones.map((milestone, index) => (
            <div class:list={[
              'relative flex items-center',
              index % 2 === 0 ? 'justify-start' : 'justify-end'
            ]}>
              <div class:list={[
                'w-5/12 bg-white p-6 border border-gray-200',
                index % 2 === 0 ? 'text-right pr-8' : 'text-left pl-8'
              ]}>
                <div class="text-2xl font-display font-bold text-primary mb-1">{milestone.year}</div>
                <div class="text-secondary font-medium">{milestone.event}</div>
              </div>
              <div class="absolute left-1/2 transform -translate-x-1/2 w-4 h-4 bg-primary border-4 border-white"></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28 bg-tertiary text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-display-md font-display font-bold mb-4">Our Values</h2>
        <p class="text-xl text-gray-400 max-w-2xl mx-auto">
          The principles that guide everything we do.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {values.map((value) => (
          <div class="text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-primary/20 mb-6">
              <svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" set:html={value.icon} />
            </div>
            <h3 class="text-xl font-display font-semibold mb-3">{value.title}</h3>
            <p class="text-gray-400">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28 bg-gradient-to-br from-primary to-primary/80 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-display-sm font-display font-bold mb-6">Want to Learn More?</h2>
      <p class="text-xl text-white/90 mb-10 max-w-2xl mx-auto">
        Get in touch and let us share how we can help transform your business.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/contact" class="btn-secondary inline-block text-lg px-8 py-4">
          Contact Us
        </a>
        <a href="/services" class="border-2 border-white text-white inline-block text-lg px-8 py-4 hover:bg-white hover:text-primary transition-all duration-200">
          View Our Services
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
