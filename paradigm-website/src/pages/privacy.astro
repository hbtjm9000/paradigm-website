---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy" description="Privacy Policy for Paradigm IT Services">
  <section class="py-16">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl font-bold text-secondary mb-8">Privacy Policy</h1>
      <div class="prose prose-lg text-gray-600">
        <p class="mb-4">Last updated: April 21, 2026</p>
        
        <h2 class="text-xl font-bold text-secondary mt-8 mb-4">Information We Collect</h2>
        <p class="mb-4">We collect information you provide directly to us, including:</p>
        <ul class="list-disc pl-6 mb-4 space-y-2">
          <li>Contact information (name, email, phone number)</li>
          <li>Business information</li>
          <li>Communication preferences</li>
        </ul>
        
        <h2 class="text-xl font-bold text-secondary mt-8 mb-4">How We Use Your Information</h2>
        <p class="mb-4">We use the information we collect to:</p>
        <ul class="list-disc pl-6 mb-4 space-y-2">
          <li>Respond to your inquiries</li>
          <li>Provide consulting services</li>
          <li>Send you relevant updates and information</li>
        </ul>
        
        <h2 class="text-xl font-bold text-secondary mt-8 mb-4">Contact Us</h2>
        <p>If you have questions about this Privacy Policy, please contact us at <a href="mailto:hello@serviceparadigm.com" class="text-primary hover:underline">hello@serviceparadigm.com</a>.</p>
      </div>
    </div>
  </section>
</BaseLayout>
