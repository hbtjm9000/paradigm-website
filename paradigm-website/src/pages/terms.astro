---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Terms of Service" description="Terms of Service for Paradigm IT Services">
  <section class="py-16">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl font-bold text-secondary mb-8">Terms of Service</h1>
      <div class="prose prose-lg text-gray-600">
        <p class="mb-4">Last updated: April 21, 2026</p>
        
        <h2 class="text-xl font-bold text-secondary mt-8 mb-4">Services</h2>
        <p class="mb-4">Paradigm IT Services provides IT consulting, managed services, and digital transformation solutions to businesses in Jamaica and the Caribbean.</p>
        
        <h2 class="text-xl font-bold text-secondary mt-8 mb-4">Payment Terms</h2>
        <p class="mb-4">Payment terms are as specified in individual service agreements. Standard terms are Net 30 unless otherwise agreed.</p>
        
        <h2 class="text-xl font-bold text-secondary mt-8 mb-4">Limitation of Liability</h2>
        <p class="mb-4">Our liability is limited to the extent permitted by law. Specific limitations are defined in individual service agreements.</p>
        
        <h2 class="text-xl font-bold text-secondary mt-8 mb-4">Contact Us</h2>
        <p>If you have questions about these Terms, please contact us at <a href="mailto:hello@serviceparadigm.com" class="text-primary hover:underline">hello@serviceparadigm.com</a>.</p>
      </div>
    </div>
  </section>
</BaseLayout>
